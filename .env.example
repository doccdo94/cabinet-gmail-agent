# ============================================================
# .env — Gmail Agent Cabinet 24 Silvestri
# NE PAS COMMITTER CE FICHIER (.gitignore)
# Configurer ces valeurs dans les variables d'environnement Render
# ============================================================

# ── ANTHROPIC ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GMAIL OAUTH2 ──────────────────────────────────────────────
# Obtenir sur console.cloud.google.com → APIs → Identifiants
GMAIL_CLIENT_ID=...apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...     # obtenu via /auth/gmail → /auth/callback
GMAIL_ADDRESS=24silvestri@gmail.com

# ── GOOGLE CLOUD PUB/SUB ──────────────────────────────────────
# Format : projects/MON_PROJECT_ID/topics/MON_TOPIC
PUBSUB_TOPIC=projects/cabinet-gmail-agent/topics/gmail-push

# ── RENDER ────────────────────────────────────────────────────
# URL publique du service Render (sans slash final)
RENDER_URL=https://gmail-agent-cabinet.onrender.com

# ── SUPABASE (S4) ─────────────────────────────────────────────
SUPABASE_URL=https://jfagpzlwlnoahhovzfkd.supabase.co
SUPABASE_KEY=eyJ...

# ── PORT (Render le fournit automatiquement) ──────────────────
PORT=3000
